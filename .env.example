# ============================================================
# MULTI-AGENT AI PLATFORM — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# ------ OpenRouter (PRIMARY LLM Gateway) -------------------
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Identifies your app in OpenRouter dashboard
OPENROUTER_APP_NAME="MultiAgent AI Platform"
OPENROUTER_APP_URL="https://your-frontend.vercel.app"

# ------ Supabase (Auth + Database) -------------------------
# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx
# Get from: Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ------ E2B (Sandboxed Code Execution) ---------------------
# Get from: https://e2b.dev/dashboard
E2B_API_KEY=e2b_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------ Composio (External Tool Integrations) --------------
# Get from: https://app.composio.dev/settings
COMPOSIO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------ App Settings ---------------------------------------
APP_ENV=production              # development | production
APP_SECRET_KEY=change-this-to-a-long-random-string-in-production
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# Rate limiting
RATE_LIMIT_PER_MINUTE=20

# ------ Optional: Direct provider fallback keys -----------
# Only used if OpenRouter is completely unreachable
# ANTHROPIC_API_KEY=sk-ant-xxxxx
